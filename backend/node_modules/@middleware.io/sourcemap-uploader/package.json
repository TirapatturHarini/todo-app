{
  "name": "@middleware.io/sourcemap-uploader",
  "version": "0.1.6",
  "description": "Command line tool to upload source maps to middleware",
  "bin": "./dist/index.js",
  "author": "Middleware",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/lib": {
      "require": "./dist/lib.cjs",
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./dist/webpack-plugin": {
      "require": "./dist/webpack-plugin.cjs",
      "import": "./dist/webpack-plugin.js",
      "types": "./dist/webpack-plugin.d.ts"
    },
    "./dist/vite-plugin": {
      "require": "./dist/vite-plugin.cjs",
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "scripts": {
    "typegen": "tsup src/index.ts src/lib.ts src/webpack-plugin src/vite-plugin --dts-only",
    "build": "tsup"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "devDependencies": {
    "@types/node": "^18.15.5",
    "vite": "^6.0.0",
    "eslint": "^8.39.0",
    "npm-run-all": "^4.1.5",
    "tsup": "6.6.2",
    "typescript": "^5.0.2"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "dependencies": {
    "commander": "^10.0.0",
    "cross-fetch": "^3.1.5",
    "express": "^4.19.2",
    "glob": "^9.3.0",
    "open": "^10.1.0"
  }
}
